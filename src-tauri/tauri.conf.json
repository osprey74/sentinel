{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sentinel",
  "version": "1.0.7",
  "identifier": "com.osprey74.sentinel",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "sentinel-main",
        "title": "Sentinel",
        "width": 220,
        "height": 640,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "closable": true,
        "skipTaskbar": true,
        "focus": true,
        "center": true,
        "shadow": false,
        "theme": "Dark"
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/lhm/**/*": "resources/lhm/"
    }
  }
}
